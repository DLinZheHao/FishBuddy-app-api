WeatherKEY = "CWA-BFB6A0E3-0705-4F0C-A8E5-5524B97BB466"

# 想抓的地理範圍（關鍵字，會自動去 iNat v2 找 place_id）
INAT_PLACE_QUERY=Taiwan

# 想抓的分類：魚類（Ray-finned fishes / Actinopterygii）
INAT_TAXON_ID=47178

# 一次抓多少（iNat v2 每頁上限 200）
INAT_PER_PAGE=200

# 只收哪些照片授權（逗號分隔）。建議含可商用：cc0,cc-by,cc-by-sa
# 若純研究或不商用可加 cc-by-nc, cc-by-nc-sa
PHOTO_LICENSE_WHITELIST=cc0,cc-by,cc-by-sa,cc-by-nc,cc-by-nc-sa

# 最多抓多少 observation（安全上限，避免一次過量）
INAT_MAX_OBS=1

# 讓 iNat 回傳中文的常用名（繁體）
INAT_LOCALE=zh-TW
# iNat 的台灣 place_id（用我們前面的自動解析就會得到正確 id；這裡只是預設）
INAT_PREFERRED_PLACE_ID=97387

# 每個物種最多幾張照片（你可自行調整）
MAX_PHOTOS_PER_TAXON=20

# 想要的圖片尺寸（square/small/medium/large/original）差 -> 好
INAT_PHOTO_SIZE=large

# 指定來源（預設一個）
ENRICH_SOURCES=wikipedia

# 外部請求逾時（毫秒）
HTTP_TIMEOUT_MS=10000